<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_subtle"
    tools:context=".ActivityFragmentos.Fragmentos.FragmentoInventario">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_subtle"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/headerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Inventario"
                        android:textColor="@color/text_primary_alt"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnMovimientosInventario"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Historial"
                        android:src="@drawable/baseline_access_time_24"
                        app:tint="@color/text_secondary" />

                    <ImageButton
                        android:id="@+id/btnImportarMasivo"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Importación masiva"
                        android:src="@drawable/ic_download"
                        android:rotation="180"
                        app:tint="@color/text_secondary" />

                    <ImageButton
                        android:id="@+id/btnInfoColores"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Info colores"
                        android:src="@drawable/ic_info"
                        app:tint="@color/text_tertiary_muted" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardbuscador"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E4E7EC"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="50dp"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/searchicon"
                            app:tint="@color/text_tertiary_muted" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editBuscarProducto"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical"
                            android:hint="Buscar..."
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/text_primary_alt"
                            android:textColorHint="@color/text_tertiary_muted"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFiltroEstado"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Todos"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_green_dark"
                    android:textSize="13sp"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_arrow_drop_down"
                    app:iconGravity="end"
                    app:iconPadding="2dp"
                    app:iconTint="@color/brand_green_dark"
                    app:strokeColor="#CFE7DC"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFiltroCategoria"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="20dp"
                    app:icon="@android:drawable/ic_menu_sort_by_size"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/text_secondary"
                    app:strokeColor="@color/border_neutral"
                    app:strokeWidth="1dp" />

            </LinearLayout>

            <!-- Alerta superior: 1 lote próximo a vencer (verde claro, no amarillo) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAlertaLotesVencer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:cardBackgroundColor="#EEF8F1"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#CFE9D8"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="@color/surface_white"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#CFE9D8"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:padding="9dp"
                            android:src="@drawable/outline_calendar_month_24"
                            app:tint="@color/brand_green_dark" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTextoAlertaLotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_medium"
                            android:text="1 lote próximo a vencer"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Vende primero los lotes por vencer."
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Ver lotes"
                        android:textColor="@color/brand_green_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="2dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/brand_green_dark" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- COMPAT — tarjeta verde grande removida del diseño limpio (oculta) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPrioridadInventario"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTituloPrioridadInventario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/tvResumenPrioridadInventario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/tvAccionPrioridadInventario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>



        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- COMPAT — carrusel removido del diseño limpio (oculto, era información duplicada) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAlertasInventario"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- COMPAT — cabecera de tabla removida (oculta) -->
            <LinearLayout
                android:id="@+id/layoutCabeceraTablaInventario"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/recyclerAlertasInventario" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutCabeceraTablaInventario" />

            <LinearLayout
                android:id="@+id/headerProductosInventario"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvTituloProductosInventario"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Productos (12)" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="Stock total: 320 uds" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@android:color/white"
                android:clipToPadding="false"
                android:paddingStart="0dp"
                android:paddingTop="2dp"
                android:paddingEnd="0dp"
                android:paddingBottom="100dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:listitem="@layout/reciclerproductosinventarios" />

            <LinearLayout
                android:id="@+id/layoutEmptySearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.35">

                <ImageView
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:contentDescription="@null"
                    android:src="@drawable/inventory_2icon"
                    app:tint="#B8D7C8" />

                <TextView
                    android:id="@+id/tvTituloEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Inventario vacío"
                    android:textColor="@color/text_primary_alt"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Aún no has agregado productos."
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAgregarPrimerProducto"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="54dp"
                    android:text="Agregar producto"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_green_dark"
                    android:textSize="16sp"
                    app:cornerRadius="20dp"
                    app:strokeColor="@color/brand_green_dark"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLimpiarBusqueda"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Limpiar filtros"
                    android:textColor="@color/brand_green_dark"
                    android:textSize="16sp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomSheetMovimientos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottomsheet_movimientos"
        android:elevation="18dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:behavior_draggable="true"
        app:behavior_fitToContents="false"
        app:behavior_halfExpandedRatio="0.62"
        app:behavior_hideable="false"
        app:behavior_peekHeight="26dp"
        app:behavior_skipCollapsed="false"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="42dp"
                android:layout_height="5dp"
                android:background="@drawable/bg_handle_bottomsheet" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="6dp"
            android:paddingEnd="18dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trazabilidad y Movimientos"
                        android:textColor="@color/text_primary_almost"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSubtituloMovimientos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Historial reciente del inventario"
                        android:textColor="#7B8188"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#E8F6EF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tvResumenMovimientos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="10dp"
                        android:paddingTop="7dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="7dp"
                        android:text="Recientes"
                        android:textColor="@color/brand_green_dark"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHoyTablet"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:checked="true"
                        android:text="Hoy"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Ayer"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Esta semana"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipFechaTablet"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Fecha"
                        android:textSize="13sp" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewMovimientos"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="110dp"
                tools:listitem="@layout/item_movimiento_inventario" />

            <TextView
                android:id="@+id/tvMovimientosVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="Aún no hay movimientos de inventario. Aparecerán aquí automáticamente."
                android:textColor="#7B8188"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- FAB circular principal abajo a la derecha -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/floatingbotoncrearproducto"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Nuevo producto"
        android:text=""
        android:textColor="@android:color/transparent"
        app:backgroundTint="@color/brand_green_dark"
        app:elevation="6dp"
        app:icon="@drawable/baseline_add_24"
        app:iconPadding="0dp"
        app:iconSize="24dp"
        app:iconTint="@color/white" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutSkeletonInventarioInicial"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/surface_subtle"
        android:clickable="true"
        android:elevation="32dp"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <View
                android:layout_width="170dp"
                android:layout_height="30dp"
                android:background="#E7ECF3" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="#E9EEF5" />

                <View
                    android:layout_width="94dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:background="#E9EEF5" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="88dp"
                    android:layout_height="32dp"
                    android:background="#EDF2F8" />

                <View
                    android:layout_width="106dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:background="#EDF2F8" />

                <View
                    android:layout_width="98dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:background="#EDF2F8" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="14dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E8EEF4"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:layout_marginBottom="10dp"
                        android:background="#F1F5FA" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:layout_marginBottom="10dp"
                        android:background="#F1F5FA" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:background="#F1F5FA" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <ProgressBar
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:indeterminateTint="@color/brand_green_soft" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
