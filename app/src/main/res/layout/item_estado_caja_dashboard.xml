<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootEstadoCaja"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="10dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardIconoEstadoCaja"
        android:layout_width="36dp"
        android:layout_height="36dp"
        app:cardBackgroundColor="#E6F4EC"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgIconoEstadoCaja"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/pos"
            app:tint="@color/brand_green_alt" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvNombreEstadoCaja"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="@font/inter_medium"
        android:maxLines="1"
        android:text="Caja"
        android:textColor="@color/text_primary_navy"
        android:textSize="14sp"
        tools:text="Caja principal" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/dotEstadoCaja"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot_dashboard_success" />

        <TextView
            android:id="@+id/tvEstadoCajaItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="@font/inter_medium"
            android:text="Abierta"
            android:textColor="@color/brand_green_alt"
            android:textSize="13sp"
            tools:text="Abierta" />
    </LinearLayout>

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="6dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/text_tertiary_alt" />
</LinearLayout>
