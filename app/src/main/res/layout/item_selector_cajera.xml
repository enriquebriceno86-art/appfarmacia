<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EEEEEE"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:background="#F5F5F5"
            app:shapeAppearanceOverlay="@style/CircleAppearance"
            app:srcCompat="@drawable/iconpersona"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreCajeraSelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre de la Cajera"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRolCajeraSelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cajera - Turno Mañana"
                android:textColor="#757575"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvEstadoCajeraSelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#FEF3C7"
                android:fontFamily="@font/inter_medium"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:text="Cuenta bloqueada"
                android:textColor="#92400E"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imgCheckCajera"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/checklisto"
            android:visibility="gone"
            android:contentDescription="Seleccionado"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
