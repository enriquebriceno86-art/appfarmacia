<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FAFAFA"
    app:strokeColor="@color/border_neutral"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <!-- Info principal -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Fila 1: hora + método -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvHoraVentaDev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:30 a.m."
                    android:textColor="@color/text_primary_almost"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_medium" />

                <TextView
                    android:id="@+id/tvMetodoPagoVentaDev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_lote_vencimiento"
                    android:paddingStart="7dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="7dp"
                    android:paddingBottom="2dp"
                    android:text="Efectivo"
                    android:textColor="@color/text_secondary_strong"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Fila 2: cliente o tipo comprobante -->
            <TextView
                android:id="@+id/tvClienteVentaDev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Boleta simple · 3 productos"
                android:textColor="@color/text_secondary_gray"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Total + badge devuelta -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTotalVentaDev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 45.00"
                android:textColor="#166534"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_medium" />

            <!-- Badge "Ya devuelta" -->
            <TextView
                android:id="@+id/tvBadgeDevuelta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:paddingStart="7dp"
                android:paddingTop="2dp"
                android:paddingEnd="7dp"
                android:paddingBottom="2dp"
                android:text="Devuelta"
                android:textColor="@color/state_error"
                android:textSize="10sp"
                android:background="@drawable/bg_chip_lote_vigente"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
