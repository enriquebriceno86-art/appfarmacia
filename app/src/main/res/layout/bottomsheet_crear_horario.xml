<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_subtle"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.ExtraLarge">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:background="#D1D5DB" />

            <TextView
                android:id="@+id/txtTituloBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configurar horario"
                android:textColor="@color/text_primary_pure"
                android:textSize="22sp"
                android:fontFamily="@font/inter_medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Configura un día y su horario de atención"
                android:textColor="@color/text_secondary_gray"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Selecciona el día"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/autoDia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textSize="15sp"
                            android:fontFamily="@font/inter_regular"
                            android:textColor="@color/text_primary_pure" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Apertura"
                                android:textColor="@color/text_secondary_gray"
                                android:textSize="12sp"
                                android:fontFamily="@font/inter_medium" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnHoraApertura"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:layout_marginTop="6dp"
                                android:text="08:00 AM"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary_pure"
                                android:textSize="14sp"
                                android:fontFamily="@font/inter_regular"
                                app:cornerRadius="12dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="@color/border_subtle" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cierre"
                                android:textColor="@color/text_secondary_gray"
                                android:textSize="12sp"
                                android:fontFamily="@font/inter_medium" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnHoraCierre"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:layout_marginTop="6dp"
                                android:text="06:00 PM"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary_pure"
                                android:textSize="14sp"
                                android:fontFamily="@font/inter_regular"
                                app:cornerRadius="12dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="@color/border_subtle" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchCerrado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Marcar como cerrado"
                        android:textColor="@color/text_primary_pure"
                        android:fontFamily="@font/inter_regular"
                        android:textSize="15sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchVeinticuatroHoras"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Atender 24 horas"
                        android:textColor="@color/text_primary_pure"
                        android:fontFamily="@font/inter_regular"
                        android:textSize="15sp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkAplicarLaborales"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Aplicar este horario a todos los días laborales (Lunes a Viernes)"
                        android:textColor="@color/text_secondary_gray"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_regular"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarHorario"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Guardar horario"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:fontFamily="@font/inter_medium"
                app:backgroundTint="@color/text_primary_pure"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarHorario"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="Eliminar horario"
                android:textAllCaps="false"
                android:textColor="@color/state_error"
                android:fontFamily="@font/inter_medium"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.core.widget.NestedScrollView>