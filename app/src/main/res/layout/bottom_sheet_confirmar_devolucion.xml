<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_white"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.ExtraLarge">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ============================================================== -->
            <!--  HANDLE                                                          -->
            <!-- ============================================================== -->
            <View
                android:layout_width="44dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_handle_bottomsheet"
                tools:background="#D5D9E0" />

            <!-- ============================================================== -->
            <!--  CONTENIDO SCROLLABLE                                            -->
            <!-- ============================================================== -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/nestedScrollDevolucion"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="16dp">

                    <!-- ====================================================== -->
                    <!--  HEADER                                                 -->
                    <!-- ====================================================== -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_medium"
                                android:text="Confirmar devolución"
                                android:textColor="@color/text_primary_pure"
                                android:textSize="22sp" />

                            <TextView
                                android:id="@+id/tvInfoVentaDevolucion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:drawablePadding="6dp"
                                android:gravity="center_vertical"
                                android:textColor="@color/text_secondary_gray"
                                android:textSize="13sp"
                                app:drawableStartCompat="@drawable/ic_info"
                                app:drawableTint="@color/text_secondary_gray"
                                tools:text="Venta · 08:30 a. m." />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_chip_gris_suave"
                            android:gravity="end"
                            android:orientation="vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.05"
                                android:text="Total original"
                                android:textAllCaps="true"
                                android:textColor="@color/text_secondary_gray"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/tvTotalOriginalMontoDev"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_medium"
                                android:textColor="@color/text_primary_pure"
                                android:textSize="13sp"
                                tools:text="S/. 45.00" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ====================================================== -->
                    <!--  SECCIÓN 1: PRODUCTOS                                   -->
                    <!-- ====================================================== -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:fontFamily="@font/inter_medium"
                        android:letterSpacing="0.08"
                        android:text="1 · PRODUCTOS"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="¿Qué se está devolviendo?"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Selecciona productos y cantidades que regresarán al inventario."
                        android:textColor="@color/text_secondary_gray"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:id="@+id/containerProductosDevolucion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />

                    <!-- ====================================================== -->
                    <!--  CARD DE MONTO A DEVOLVER                               -->
                    <!-- ====================================================== -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardResumenDevolucion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="#E1F5EE"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter_medium"
                                    android:text="Monto a devolver"
                                    android:textColor="#04342C"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/tvDetalleResumenDevolucion"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Basado en los items seleccionados."
                                    android:textColor="#0F6E56"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvTotalADevolver"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:fontFamily="@font/inter_medium"
                                android:textColor="#0F6E56"
                                android:textSize="22sp"
                                tools:text="S/. 30.00" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ====================================================== -->
                    <!--  SECCIÓN 2: RESOLUCIÓN                                  -->
                    <!-- ====================================================== -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:fontFamily="@font/inter_medium"
                        android:letterSpacing="0.08"
                        android:text="2 · RESOLUCIÓN"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="¿Cómo se resolvió?"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="15sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutTipoResolucionDevolucion"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Selecciona una opción"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvTipoResolucionDevolucion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_regular"
                            android:inputType="none"
                            android:padding="14dp"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ============================ -->
                    <!--  PANEL SUSTITUCIÓN (oculto)   -->
                    <!-- ============================ -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/layoutSustitucionDevolucion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="#EEEDFE"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#AFA9EC"
                        app:strokeWidth="1dp"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawablePadding="6dp"
                                android:fontFamily="@font/inter_medium"
                                android:gravity="center_vertical"
                                android:text="Producto sustituto"
                                android:textColor="#3C3489"
                                android:textSize="13sp"
                                app:drawableStartCompat="@drawable/ic_info"
                                app:drawableTint="#3C3489" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSeleccionarProductoSustitucionDevolucion"
                                style="@style/Widget.Material3.Button.UnelevatedButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="10dp"
                                android:text="Buscar producto sustituto"
                                android:textAllCaps="false"
                                android:textColor="#3C3489"
                                android:textSize="13sp"
                                app:backgroundTint="@color/surface_white"
                                app:cornerRadius="12dp"
                                app:icon="@drawable/searchicon"
                                app:iconPadding="8dp"
                                app:iconSize="18dp"
                                app:iconTint="#3C3489"
                                app:strokeColor="#AFA9EC"
                                app:strokeWidth="1dp" />

                            <!-- Card del producto seleccionado -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                app:cardBackgroundColor="@color/surface_white"
                                app:cardCornerRadius="10dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="10dp">

                                    <TextView
                                        android:id="@+id/etProductoSustitucionDevolucion"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/inter_medium"
                                        android:hint="Producto no seleccionado"
                                        android:textColor="@color/text_primary_pure"
                                        android:textColorHint="@color/text_secondary_gray"
                                        android:textSize="13sp"
                                        tools:text="Amoxicilina 500mg" />

                                    <TextView
                                        android:id="@+id/tvResumenProductoSustitucionDevolucion"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:text="Elige el producto que entregarás al cliente."
                                        android:textColor="@color/text_secondary_gray"
                                        android:textSize="11sp" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Grid: Presentación + Cantidad -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal">

                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/layoutPresentacionSustitucionDevolucion"
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:layout_weight="1.6"
                                    android:hint="Presentación"
                                    app:boxBackgroundColor="@color/surface_white"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp">

                                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                        android:id="@+id/actvPresentacionSustitucionDevolucion"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="none"
                                        android:padding="12dp"
                                        android:textSize="13sp" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/layoutCantidadSustitucionDevolucion"
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:hint="Cant."
                                    app:boxBackgroundColor="@color/surface_white"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/etCantidadSustitucionDevolucion"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:inputType="number"
                                        android:padding="12dp"
                                        android:textSize="13sp" />
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvAyudaSustitucionDevolucion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Selecciona el producto y la presentación que saldrán del inventario."
                                android:textColor="#534AB7"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ====================================================== -->
                    <!--  CARD: BALANCE ECONÓMICO (oculto por defecto)           -->
                    <!-- ====================================================== -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardResumenDiferenciaDevolucion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="#F8FAFC"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#E2E8F0"
                        app:strokeWidth="1dp"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tvResumenResolucionDevolucion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_medium"
                                android:text="Balance económico"
                                android:textColor="@color/text_primary_pure"
                                android:textSize="13sp" />

                            <LinearLayout
                                android:id="@+id/layoutMontoProductoDevueltoDevolucion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Crédito por devolución"
                                    android:textColor="@color/text_secondary_gray"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvMontoProductoDevueltoDevolucion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter_medium"
                                    android:textColor="@color/text_primary_pure"
                                    android:textSize="13sp"
                                    tools:text="S/. 30.00" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/layoutMontoProductoSustitutoDevolucion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Valor nuevo producto"
                                    android:textColor="@color/text_secondary_gray"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvMontoProductoSustitutoDevolucion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter_medium"
                                    android:textColor="@color/text_primary_pure"
                                    android:textSize="13sp"
                                    tools:text="S/. 36.00" />
                            </LinearLayout>

                            <View
                                android:id="@+id/viewSeparadorDiferenciaDevolucion"
                                android:layout_width="match_parent"
                                android:layout_height="0.5dp"
                                android:layout_marginTop="12dp"
                                android:background="#CBD5E1" />

                            <LinearLayout
                                android:id="@+id/layoutValorDiferenciaDevolucion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tvLabelDiferenciaDevolucion"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_medium"
                                    android:textColor="@color/text_primary_pure"
                                    android:textSize="13sp"
                                    tools:text="Diferencia a cobrar" />

                                <TextView
                                    android:id="@+id/tvValorDiferenciaDevolucion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter_medium"
                                    android:textColor="#185FA5"
                                    android:textSize="18sp"
                                    tools:text="S/. 6.00" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDiferenciaDevolucion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_chip_gris_suave"
                                android:backgroundTint="#E6F1FB"
                                android:padding="10dp"
                                android:text="Aquí verás el resultado económico."
                                android:textColor="#0C447C"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ====================================================== -->
                    <!--  SECCIÓN 3: PAGO DE DIFERENCIA (oculto)                 -->
                    <!-- ====================================================== -->
                    <LinearLayout
                        android:id="@+id/layoutPagoDiferenciaDevolucion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:fontFamily="@font/inter_medium"
                            android:letterSpacing="0.08"
                            android:text="3 · PAGO DE LA DIFERENCIA"
                            android:textColor="#9CA3AF"
                            android:textSize="10sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutMetodoPagoDiferenciaDevolucion"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1.6"
                                android:hint="Medio de pago"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusTopStart="12dp">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/actvMetodoPagoDiferenciaDevolucion"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none"
                                    android:padding="12dp"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutMontoPagoDiferenciaDevolucion"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Monto"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusTopStart="12dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etMontoPagoDiferenciaDevolucion"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:inputType="numberDecimal"
                                    android:padding="12dp"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvAyudaPagoDiferenciaDevolucion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:paddingHorizontal="2dp"
                            android:text="Confirma el monto exacto de la diferencia."
                            android:textColor="@color/text_secondary_gray"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- ====================================================== -->
                    <!--  SECCIÓN 4: MOTIVO                                      -->
                    <!-- ====================================================== -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:fontFamily="@font/inter_medium"
                        android:letterSpacing="0.08"
                        android:text="4 · MOTIVO"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutMotivoDevolucion"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Motivo de la devolución"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:counterEnabled="true"
                        app:counterMaxLength="120">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMotivoDevolucion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_regular"
                            android:inputType="textCapSentences|textMultiLine"
                            android:maxLength="120"
                            android:maxLines="3"
                            android:minLines="1"
                            android:padding="14dp"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ====================================================== -->
                    <!--  AVISO DE STOCK                                         -->
                    <!-- ====================================================== -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_dashboard_panel"
                        android:backgroundTint="#FAEEDA"
                        android:gravity="top"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:layout_marginTop="1dp"
                            android:src="@drawable/ic_info"
                            app:tint="#854F0B" />

                        <TextView
                            android:id="@+id/tvAvisoStockDevolucion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:lineSpacingExtra="2dp"
                            android:text="El stock de los productos seleccionados se restaurará automáticamente al inventario."
                            android:textColor="#633806"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- ============================================================== -->
            <!--  FOOTER FIJO                                                     -->
            <!-- ============================================================== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_white"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelarDevolucionSheet"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:text="Cancelar"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary_pure"
                    android:textSize="15sp"
                    app:cornerRadius="26dp"
                    app:strokeColor="#D1D5DB" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmarDevolucionSheet"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1.4"
                    android:text="Confirmar"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    app:backgroundTint="#0F6E56"
                    app:cornerRadius="26dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>