<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header con fecha y hora de apertura -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resumen del turno"
                        android:textColor="@color/text_primary_dark"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_medium" />

                    <TextView
                        android:id="@+id/tvFechaTurnoResumen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"
                        android:text="Hoy · Abierto desde las 08:00"
                        android:textColor="@color/text_secondary_gray"
                        android:textSize="13sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="En curso"
                    android:textColor="@color/brand_green_success"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:fontFamily="@font/inter_medium"
                    />

            </LinearLayout>

            <!-- Tarjetas de total vendido y efectivo en caja -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#F0FDF4"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total vendido"
                            android:textColor="@color/brand_green_success"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/tvTotalVentasResumen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="S/ 0.00"
                            android:textColor="#166534"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_regular" />

                        <TextView
                            android:id="@+id/tvNumeroVentasResumen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 ventas"
                            android:textColor="@color/text_secondary_gray"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#FEFCE8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Efectivo en caja"
                            android:textColor="#CA8A04"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/tvEfectivoEsperadoResumen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="S/ 0.00"
                            android:textColor="#A16207"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_regular" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Diferencia: S/ 0.00"
                            android:textColor="@color/text_secondary_gray"
                            android:textSize="12sp"
                            android:visibility="gone" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Badge de estado del cuadre -->
            <LinearLayout
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="✓ Cuadrado"
                    android:textColor="@color/brand_green_success"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_medium"
                    />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:background="@color/border_neutral" />

            <!-- Métodos de pago -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Por método de pago"
                android:textColor="@color/text_secondary_strong"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_medium"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerResumenMetodos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvResumenSinVentas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="Sin ventas registradas en este turno"
                android:textColor="@color/text_disabled"
                android:textSize="13sp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:background="@color/border_neutral" />

            <!-- Cuadre de caja (fórmula) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuadre de caja"
                android:textColor="@color/text_secondary_strong"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_medium"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#F9FAFB"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_neutral"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Apertura de caja"
                            android:textColor="@color/text_secondary_gray"
                            android:textSize="13sp"
                            android:gravity="start" />

                        <TextView
                            android:id="@+id/tvMontoAperturaResumen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/ 0.00"
                            android:textColor="@color/text_primary_dark"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_medium"
                            android:gravity="end" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="+ Ventas en efectivo"
                            android:textColor="@color/text_secondary_gray"
                            android:textSize="13sp"
                            android:gravity="start" />

                        <TextView
                            android:id="@+id/tvVentasEfectivoResumen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/ 0.00"
                            android:textColor="#166534"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_medium"
                            android:gravity="end" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="− Egresos"
                            android:textColor="@color/text_secondary_gray"
                            android:textSize="13sp"
                            android:gravity="start" />

                        <TextView
                            android:id="@+id/tvEgresosCuadreResumen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/ 0.00"
                            android:textColor="@color/state_error"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_medium"
                            android:gravity="end" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/border_neutral" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="= Caja final teórica"
                            android:textColor="@color/text_primary_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="start" />

                        <TextView
                            android:id="@+id/tvCajaFinalTeoricaResumen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/ 0.00"
                            android:textColor="#166534"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_medium"
                            android:gravity="end" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Top productos más vendidos -->
            <TextView
                android:id="@+id/tvTopProductosTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="🏆 Más vendidos"
                android:textColor="@color/text_secondary_strong"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_medium"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutTopProductos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:visibility="gone" />

            <!-- Footer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:background="@color/border_neutral" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apertura"
                        android:textColor="@color/text_disabled"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvHoraAperturaResumen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="@color/text_secondary_strong"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_medium" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Última venta"
                        android:textColor="@color/text_disabled"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvUltimaVentaResumen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="@color/text_secondary_strong"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_medium" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Botón fijo -->
    <com.google.android.material.button.MaterialButton
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="Cerrar turno"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        android:visibility="gone"
        app:backgroundTint="@color/colorazul" />

</LinearLayout>