<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_subtle"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIconoUsuario"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardBackgroundColor="#D0E3FF"
            app:cardCornerRadius="26dp"
            app:strokeWidth="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="👤"
                android:textSize="22sp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtNombreSolicitud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter_medium"
            android:maxLines="1"
            android:textColor="@color/text_primary_alt"
            android:textSize="16sp"
            app:layout_constraintEnd_toStartOf="@+id/cardEstadoSolicitud"
            app:layout_constraintStart_toEndOf="@id/cardIconoUsuario"
            app:layout_constraintTop_toTopOf="@id/cardIconoUsuario" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEstadoSolicitud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FEF3C7"
            app:cardCornerRadius="14dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="@id/txtNombreSolicitud"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/txtEstadoSolicitud"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textColor="@color/state_warning"
                android:textSize="12sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtRolSolicitud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/text_secondary_gray"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/cardEstadoSolicitud"
            app:layout_constraintStart_toStartOf="@id/txtNombreSolicitud"
            app:layout_constraintTop_toBottomOf="@id/txtNombreSolicitud" />

        <TextView
            android:id="@+id/txtDocumentoSolicitud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary_strong"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/txtNombreSolicitud"
            app:layout_constraintTop_toBottomOf="@id/txtRolSolicitud" />

        <View
            android:id="@+id/dividerSolicitud"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/divider_alt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/txtNombreSolicitud"
            app:layout_constraintTop_toBottomOf="@id/txtDocumentoSolicitud" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dividerSolicitud">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRechazarSolicitud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="Rechazar"
                android:textAllCaps="false"
                android:textColor="@color/state_error"
                android:textSize="13sp"
                app:backgroundTint="#FEE2E2"
                app:cornerRadius="20dp"
                app:elevation="0dp"
                app:iconTint="@color/state_error"
                app:strokeColor="#FCA5A5"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAprobarSolicitud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:text="Aprobar"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                app:backgroundTint="#2563EB"
                app:cornerRadius="20dp"
                app:elevation="0dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>