<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="#D1D5DB"
        android:backgroundTint="#D1D5DB" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registrar devolución"
            android:textColor="@color/text_primary_almost"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_medium" />

        <TextView
            android:id="@+id/tvSubtituloDevolucion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Ventas del turno actual"
            android:textColor="@color/text_secondary_gray"
            android:textSize="12sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F2F5" />


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutBusquedaDevolucion"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="8dp"
        app:startIconDrawable="@drawable/searchicon"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBuscarDevolucion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar por monto, cliente o Nro. boleta..."
            android:inputType="text"
            android:maxLines="1"
            android:paddingVertical="10dp"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressDevolucion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:visibility="visible" />

    <!-- Lista de ventas -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:visibility="gone"
        android:id="@+id/scrollVentasDevolucion">

        <LinearLayout
            android:id="@+id/containerVentasDevolucion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp" />

    </ScrollView>

    <!-- Estado vacío -->
    <LinearLayout
        android:id="@+id/layoutSinVentasDevolucion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sin ventas en este turno"
            android:textColor="@color/text_secondary_gray"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="No hay ventas finalizadas para devolver"
            android:textColor="@color/text_disabled"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
