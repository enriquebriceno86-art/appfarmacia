<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProductoCatalogo"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/border_subtle"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="150dp"
            android:layout_height="100dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/imgProductoCatalogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:background="@color/surface_subtle"
                android:src="@drawable/iconpastillas" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvNombreProductoCatalogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter_semibold"
            android:maxLines="2"
            android:minLines="2"
            android:text="Panadol"
            android:textColor="@color/text_primary_pure"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvPresentacionProductoCatalogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter_regular"
            android:maxLines="2"
            android:minLines="2"
            android:text="caja (80 unidades)"
            android:textColor="@color/text_tertiary_muted"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvEstadoProductoCatalogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="#FDECEC"
            android:fontFamily="@font/inter_medium"
            android:gravity="start|center_vertical"
            android:maxLines="2"
            android:minLines="2"
            android:paddingStart="10dp"
            android:paddingTop="3dp"
            android:paddingEnd="10dp"
            android:paddingBottom="3dp"
            android:text="Producto agotado"
            android:textColor="#C94747"
            android:textSize="10sp"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/tvPrecioProductoCatalogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/inter_semibold"
            android:text="$25.00"
            android:textStyle="bold"
            android:textColor="@color/text_primary_pure"
            android:textSize="15sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
