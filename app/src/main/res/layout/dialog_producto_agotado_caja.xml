<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"

    android:paddingBottom="20dp">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_icon_error">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/deleteiconitem"
            app:tint="#D92D20" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvTituloProductoAgotadoCaja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="Producto sin stock"
        android:textColor="@color/text_primary_pure"
        android:fontFamily="@font/inter_regular"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMensajeProductoAgotadoCaja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:fontFamily="@font/inter_regular"
        android:lineSpacingExtra="2dp"
        android:text="Este producto ya no tiene una presentación disponible para continuar. Lo mejor es quitarlo de la caja para seguir con la venta."
        android:textColor="@color/black"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEliminarProductoAgotadoCaja"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="Eliminar"
        android:textAllCaps="false"
        android:textSize="12dp"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/text_primary_pure"
        app:cornerRadius="30dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelarProductoAgotadoCaja"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Cancelar"
        android:textSize="12dp"
        app:strokeColor="@color/black"
        app:strokeWidth="0.5dp"
        android:textAllCaps="false"
        android:textColor="#5F6368" />

</LinearLayout>
