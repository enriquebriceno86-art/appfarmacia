<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:layout_margin="8dp"
    android:background="@drawable/bg_bottom_sheet">


    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
        >

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:background="#D1D5DB" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_semibold"
                android:text="Agregar forma de venta"
                android:textColor="@color/text_primary_pure"
                android:textSize="28sp"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/inter_regular"
                android:text="Por ejemplo: si vende cajas, blíster o paquetes, agréguelos aquí."
                android:textColor="@color/text_secondary_gray"
                android:textSize="16sp" />

            <!-- FORM CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNombrePresentacionSheet"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        android:hint="¿Qué va a vender?">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/etNombrePresentacionSheet"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:padding="16dp"
                            android:inputType="none"
                            android:textSize="16sp"
                            android:fontFamily="@font/inter_regular" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCantidadPresentacionSheet"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        android:hint="¿Cuántas unidades trae?"
                        app:helperText="Ejemplo: si 1 blíster trae 10 tabletas, escribe 10.">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCantidadPresentacionSheet"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:inputType="numberDecimal"
                            android:textSize="16sp"
                            android:fontFamily="@font/inter_regular" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        android:hint="Precio de venta al cliente"
                        >

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPrecioPresentacionSheet"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:inputType="numberDecimal"
                            android:textSize="16sp"
                            android:fontFamily="@font/inter_regular" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarPresentacionSheet"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Guardar forma de venta"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:fontFamily="@font/inter_semibold"
                app:backgroundTint="@color/verdebotones"
                app:cornerRadius="18dp" />

        </LinearLayout>

</androidx.core.widget.NestedScrollView>
