<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_subtle"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgAiIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_ai_stars"
                app:tint="@color/text_secondary_blue" />

            <TextView
                android:id="@+id/txtAiBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_badge_ai"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="IA"
                android:textColor="@color/text_secondary_blue"
                android:textSize="10sp"
                android:fontFamily="@font/inter_bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnDiscardAi"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/close_24"
                app:tint="@color/text_secondary_gray" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtAiTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inter_bold"
            android:textColor="@color/text_primary_pure"
            android:textSize="15sp"
            tools:text="Sugerencia Inteligente" />

        <TextView
            android:id="@+id/txtAiDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary_gray"
            android:textSize="13sp"
            tools:text="Basado en tu ubicación y tipo de negocio, te sugerimos este horario inicial." />

        <TextView
            android:id="@+id/txtAiDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_secondary_blue"
            android:textSize="12sp"
            android:fontFamily="@font/inter_medium"
            android:visibility="gone"
            tools:visibility="visible"
            tools:text="Ventas detectadas hasta las 9:30 PM" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewAiDetail"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver detalle"
                android:textColor="@color/text_secondary_blue"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplyAi"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Aplicar"
                app:backgroundTint="@color/text_primary_pure"
                app:icon="@drawable/ic_check_circle"
                app:iconTint="@color/white"
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
