<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/surface_white"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:strokeColor="#E7EAF1"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvCajaCajera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Caja 01 · María Quispe"
            android:textColor="@color/text_primary_dark"
            android:textSize="10dp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_semibold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvEstadoBadge"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvEstadoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_estado_pendiente"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="Pendiente"
            android:textColor="#9A6400"
            android:textSize="10dp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/tvCajaCajera"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvTurno"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Turno tarde"
            android:textColor="@color/text_secondary_gray"
            android:textSize="10dp"
            android:fontFamily="@font/inter_semibold"
            app:layout_constraintStart_toStartOf="@id/tvCajaCajera"
            app:layout_constraintTop_toBottomOf="@id/tvCajaCajera"
            app:layout_constraintEnd_toStartOf="@id/tvEstadoBadge"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:id="@+id/layoutEstadoDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvTurno"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivEstado"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/baseline_access_time_24"
                app:tint="#C58A17" />

            <TextView
                android:id="@+id/tvEstadoDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Pendiente de cierre"
                android:textColor="#9A6400"
                android:textSize="10dp"
                android:fontFamily="@font/inter_regular"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <View
            android:id="@+id/viewDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="#ECEEF3"
            app:layout_constraintTop_toBottomOf="@id/layoutEstadoDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layoutResumenTurno"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/viewDivider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/labelInicio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reportes_label_inicio"
                    android:textColor="#3E4654"
                    android:textSize="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvInicio"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvInicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/ 0.00"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="10dp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_regular"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/labelInicio"
                    tools:ignore="HardcodedText" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/labelCantidadVentas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reportes_label_ventas_realizadas"
                    android:textColor="#3E4654"
                    android:textSize="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvCantidadVentas"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvCantidadVentas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="10dp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_regular"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/labelCantidadVentas"
                    tools:ignore="HardcodedText" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/labelVentas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reportes_label_ventas"
                    android:textColor="#3E4654"
                    android:textSize="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvVentas"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvVentas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/ 250.00"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="10dp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_regular"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/labelVentas"
                    tools:ignore="HardcodedText" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/labelEgresos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reportes_label_egresos"
                    android:textColor="#3E4654"
                    android:textSize="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvEgresos"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvEgresos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/ 0.00"
                    android:textColor="#A63A2F"
                    android:textSize="10dp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_regular"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/labelEgresos"
                    tools:ignore="HardcodedText" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/labelDevoluciones"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reportes_label_devoluciones"
                    android:textColor="#3E4654"
                    android:textSize="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvDevoluciones"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvDevoluciones"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/ 0.00"
                    android:textColor="#A63A2F"
                    android:textSize="10dp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_regular"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/labelDevoluciones"
                    tools:ignore="HardcodedText" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/layoutResultadoGanancia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/tvResultadoGananciaLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/reportes_label_ganancia"
                    android:textColor="#245B4B"
                    android:textSize="10dp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvResultadoGananciaMonto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/ 0.00"
                    android:textColor="#245B4B"
                    android:textSize="10dp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccionReporte"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Revisar reporte"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="10dp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_regular"
            app:backgroundTint="#000000"
            app:cornerRadius="30dp"
            app:layout_constraintTop_toBottomOf="@id/layoutResumenTurno"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="HardcodedText" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
