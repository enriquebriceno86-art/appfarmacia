<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/surface_white"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#EEF1F3"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="80dp"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIconoMovimiento"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#E8F6EF"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvIconoMovimiento"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/brand_green_dark"
                android:textSize="18sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTituloMovimiento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingreso: Amoxicilina 500mg"
                android:textColor="#1F2328"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetalleMovimiento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Hoy 10:30 AM · Factura #F450"
                android:textColor="#7A8087"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCantidadMovimiento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+50"
            android:textColor="#43A37A"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>