<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <!-- Ícono de tipo (entrada / salida / ajuste) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F3F4F6">

        <TextView
            android:id="@+id/tvIconoMovLote"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="↑"
            android:textSize="16sp"
            android:textColor="@color/brand_green_success" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Contenido principal -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCantidadMovLote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_medium"
                android:text="+100 unidades"
                android:textColor="@color/text_primary_almost"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTipoMovLote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_lote_vencimiento"
                android:paddingStart="7dp"
                android:paddingTop="2dp"
                android:paddingEnd="7dp"
                android:paddingBottom="2dp"
                android:text="Entrada"
                android:textColor="@color/text_secondary_strong"
                android:textSize="11sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvMotivoMovLote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Compra al proveedor"
                android:textColor="@color/text_secondary_gray"
                android:textSize="12sp"
                android:ellipsize="end"
                android:maxLines="1" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvCostoMovLote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Costo total de este movimiento: Bs 0.00"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Fecha + usuario -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFechaMovLote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="14/04/26"
            android:textColor="@color/text_secondary_strong"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium" />

        <TextView
            android:id="@+id/tvUsuarioMovLote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="Admin"
            android:textColor="@color/text_disabled"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>
