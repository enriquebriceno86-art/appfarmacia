<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_medium"
                android:text="Lotes del producto"
                android:textColor="@color/text_primary_almost"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtituloLotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Sin lotes registrados"
                android:textColor="@color/text_secondary_gray"
                android:textSize="13sp" />

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#EEF2FF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvConteoLotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="0 lotes"
                android:textColor="#4F46E5"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResumenConsumoLotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/surface_subtle_blue"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeColor="#DCE3EA"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_medium"
                android:text="Consumo de lotes"
                android:textColor="@color/text_primary_alt"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvLoteConsumoActual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Lote en consumo actual: FEFO automatico"
                android:textColor="@color/text_primary_alt"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvLoteFefoRecomendado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Recomendado por FEFO: -"
                android:textColor="@color/text_secondary_slate"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvAyudaConsumoLotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Toca un lote para dejarlo como lote de consumo manual."
                android:textColor="#64748B"
                android:textSize="12sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUsarFefoAutomatico"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Usar FEFO automatico"
        android:textAllCaps="false"
        android:textColor="#2563EB"
        app:cornerRadius="12dp"
        app:strokeColor="#BFDBFE"
        app:strokeWidth="1dp" />

    <!-- Lista de lotes (ScrollView) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:maxHeight="300dp"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/containerLotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutLotesVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦"
            android:textSize="32sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Aun no hay lotes registrados.\nLos lotes nuevos se crean al ingresar stock."
            android:textColor="@color/text_disabled"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Botón agregar lote -->
    <com.google.android.material.button.MaterialButton
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        android:text="+ Agregar lote manualmente"
        android:textAllCaps="false"
        android:textSize="12dp"
        android:textColor="@color/brand_green_dark"
        app:cornerRadius="12dp"
        app:strokeColor="@color/brand_green_dark"
        app:strokeWidth="1dp" />

</LinearLayout>
