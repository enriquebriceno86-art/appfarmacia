<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="#E4ECF5"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#F1F5F9"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imageMetodoIcono"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:padding="13dp"
                    android:src="@drawable/iconoefectivo"
                    app:tint="#102A43" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textTituloMetodo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:text="Efectivo"
                    android:textColor="#102A43"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textCategoriaMetodo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Efectivo"
                    android:textColor="#64748B"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textEstadoMetodo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_estado_activo"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Activo"
                android:textColor="#1B5E20"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textResumenMetodo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="3dp"
            android:text="Permite vuelto, solicita monto recibido, calcula vuelto."
            android:textColor="#475569"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="#F1F5F9" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarMetodo"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginEnd="10dp"
                android:text="Editar"
                android:textAllCaps="false"
                android:textColor="#102A43"
                android:textSize="14sp"
                app:cornerRadius="14dp"
                app:icon="@drawable/outline_edit_24"
                app:iconSize="18dp"
                app:iconTint="#102A43" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarMetodo"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Quitar"
                android:textAllCaps="false"
                android:textColor="#B91C1C"
                android:textSize="14sp"
                app:backgroundTint="#FEE2E2"
                app:cornerRadius="14dp"
                app:icon="@drawable/deleteiconitem"
                app:iconSize="18dp"
                app:iconTint="#B91C1C" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
