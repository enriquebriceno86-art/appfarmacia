<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:background="@color/white"
    android:paddingBottom="18dp">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_icon_error"
        android:foregroundGravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_info"
            app:tint="#C2410C" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvTituloTurnoPendiente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/inter_medium"
        android:gravity="center"
        android:text="Turno pendiente detectado"
        android:textColor="@color/text_primary_pure"
 />

    <TextView
        android:id="@+id/tvSubtituloTurnoPendiente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Esta caja sigue trabajando con un turno anterior"
        android:textColor="#7C2D12"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvMensajeTurnoPendiente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:text="Mensaje"
        android:textColor="#4B5563"
        android:textSize="14sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#FFF7ED"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#FED7AA"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_info"
                app:tint="#C2410C" />

            <TextView
                android:id="@+id/tvDetalleTurnoPendiente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Puedes seguir operando con este turno y cerrarlo cuando termines pero recuerda el cierre se hara con la fecha de ayer."
                android:textColor="#9A3412"
                android:textSize="11sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEntendidoTurnoPendiente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12dp"
        android:layout_marginTop="22dp"
        android:text="Entendido"
        android:textAllCaps="false"
        android:textColor="@color/surface_white"
        app:backgroundTint="@color/black"
        app:cornerRadius="16dp" />

</LinearLayout>
