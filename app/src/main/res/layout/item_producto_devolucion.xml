<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#E4ECF5"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/checkboxProductoDev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:buttonTint="#1F9D6A" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreProductoDev"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_medium"
                    android:maxLines="2"
                    android:text="Paracetamol 500mg"
                    android:textColor="@color/text_primary_pure"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvDetalleProductoDev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Vendido: 1 caja"
                    android:textColor="@color/text_secondary_gray"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSubtotalProductoDev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/inter_medium"
                android:text="$10.00"
                android:textColor="#059669"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvEstadoProductoDev"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FEF3C7"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Disponible para devolver: 1 caja"
            android:textColor="#92400E"
            android:textSize="12sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvEquivalenciaDev"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Equivale a 0 unidades"
            android:textColor="@color/text_secondary_gray"
            android:textSize="11sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/layoutCantidadProductoDev"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvLabelCantidadDev"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cantidad a devolver"
                android:textColor="@color/text_primary_pure"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_panel"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="2dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRestarCantidadDev"
                    style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/baseline_remove_24"
                    app:iconPadding="0dp"
                    app:iconSize="20dp" />

                <TextView
                    android:id="@+id/etCantidadProductoDev"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/text_primary_pure"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSumarCantidadDev"
                    style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/baseline_add_24"
                    app:iconPadding="0dp"
                    app:iconSize="20dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvErrorCantidadDev"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="Error de cantidad"
            tools:visibility="visible" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
