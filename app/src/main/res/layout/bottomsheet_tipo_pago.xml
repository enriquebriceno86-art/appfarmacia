<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:background="@drawable/bg_bottom_sheet">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_white"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.ExtraLarge">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="14dp"
            android:paddingEnd="28dp"
            android:paddingBottom="28dp">

            <View
                android:id="@+id/viewHandleCobro"
                android:layout_width="52dp"
                android:layout_height="5dp"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"
                android:background="#D5D9E0" />

            <!-- Stepper mas discreto -->
            <LinearLayout
                android:id="@+id/layoutStepperCobro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@drawable/bg_chip_borde_redondo"
                        android:gravity="center"
                        android:text="&#x2713;"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        app:backgroundTint="@color/brand_green_soft" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Productos"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="18dp"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="#D8DEE9" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@drawable/bg_chip_borde_redondo"
                        android:gravity="center"
                        android:text="&#x2713;"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        app:backgroundTint="@color/brand_green_soft" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Comprobante"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="18dp"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="#D8DEE9" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@drawable/bg_chip_borde_redondo"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        app:backgroundTint="@color/text_primary_pure" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Cobro"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Header -->
            <TextView
                android:id="@+id/tvTituloCobro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_medium"
                android:text="Cobrar venta"
                android:textColor="@color/text_primary_pure"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/tvSubtituloCobro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Selecciona el m&#xE9;todo de pago"
                android:textColor="@color/text_secondary_gray"
                android:textSize="15sp" />

            <!-- Total -->
            <TextView
                android:id="@+id/tvTotalPagar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/inter_medium"
                android:text="$0.00"
                android:textColor="@color/text_primary_pure"
                android:textSize="38sp"
                android:visibility="visible" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:background="@color/divider" />

            <!-- Metodos -->
            <TextView
                android:id="@+id/tvLabelMetodosPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/inter_medium"
                android:text="M&#xE9;todo de pago"
                android:textColor="@color/text_primary_pure"
                android:textSize="16sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMetodosPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <!-- Card detalle -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDetalleMetodo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#FAFBFC"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_neutral"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvDetalleTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="Detalle del pago"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text=""
                        android:textColor="@color/text_secondary_gray"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvDescripcionMetodo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_secondary_gray"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- EFECTIVO -->
                    <LinearLayout
                        android:id="@+id/layoutDetalleEfectivo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical"
                        android:visibility="gone">


                        <!-- Chips rapidos -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/txtResultadoLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cambio"
                                android:textColor="@color/text_secondary_gray"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvResultadoPago"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_medium"
                                android:text="$0.00"
                                android:textColor="@color/text_primary_pure"
                                android:textSize="22sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/inter_medium"
                            android:text="Monto recibido"
                            android:textColor="@color/text_primary_pure"
                            android:textSize="15sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layoutMontoRecibido"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtMontoRecibido"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_regular"
                                android:hint="Ej. 500"
                                android:inputType="numberDecimal"
                                android:textSize="18sp" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- TRANSFERENCIA -->
                    <LinearLayout
                        android:id="@+id/layoutDetalleTransferencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvBanco"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Banco: -"
                            android:textColor="@color/text_secondary_strong"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTipoCuenta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Tipo de cuenta: -"
                            android:textColor="@color/text_secondary_strong"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvNumeroCuenta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="N&#xFA;mero: -"
                            android:textColor="@color/text_secondary_strong"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTitularBanco"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Titular: -"
                            android:textColor="@color/text_secondary_strong"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDocumentoBanco"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Documento: -"
                            android:textColor="@color/text_secondary_strong"
                            android:textSize="14sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layoutReferenciaTransferencia"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="Referencia"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtReferenciaTransferencia"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_regular"
                                android:inputType="text" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- BILLETERA -->
                    <LinearLayout
                        android:id="@+id/layoutDetalleBilletera"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvTitularBilletera"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Titular: -"
                            android:textColor="@color/text_secondary_strong"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTelefonoBilletera"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Tel&#xE9;fono: -"
                            android:textColor="@color/text_secondary_strong"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvAliasBilletera"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Alias: -"
                            android:textColor="@color/text_secondary_strong"
                            android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvInstruccionesBilletera"
                        android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                        android:text="Instrucciones: -"
                        android:textColor="@color/text_secondary_gray"
                        android:textSize="13sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="N.&#xB0; de operaci&#xF3;n"
                        android:visibility="gone"
                        app:boxBackgroundColor="@android:color/white"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_regular"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQrBilletera"
                            android:layout_width="180dp"
                            android:layout_height="180dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="16dp"
                            android:visibility="gone"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/border_subtle"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/imgQrBilletera"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerInside"
                                android:src="@android:drawable/ic_menu_gallery" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDetalleGenerico"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Este m&#xE9;todo no requiere datos adicionales."
                        android:textColor="@color/text_secondary_gray"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pago mixto -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPagoMixto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FAFBFC"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_neutral"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="Pago mixto"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvDescripcionMixto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Activa los m&#xE9;todos que vas a usar y reparte el monto con calma."
                        android:textColor="@color/text_secondary_gray"
                        android:textSize="13sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPagoMixto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:nestedScrollingEnabled="false" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total asignado"
                            android:textColor="@color/text_secondary_gray"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTotalMixto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_medium"
                            android:text="$0.00"
                            android:textColor="@color/text_primary_pure"
                            android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>




            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelarCobro"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="Volver"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary_pure"
                    android:fontFamily="@font/inter_medium"
                    android:textSize="16sp"
                    android:visibility="gone"
                    app:cornerRadius="29dp"
                    app:strokeColor="#D9DEE8" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmarVenta"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="Confirmar cobro"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/inter_medium"
                    android:textSize="16sp"
                    app:backgroundTint="#1F9D6A"
                    app:cornerRadius="29dp" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.core.widget.NestedScrollView>
