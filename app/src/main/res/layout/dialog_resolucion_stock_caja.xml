<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#B30F172A"
    android:clickable="true"
    android:focusable="true"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/tvBadgeResolucionStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_warning"
                android:fontFamily="@font/inter_medium"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="Stock actualizado"
                android:textColor="#B54708"
                android:textSize="12sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginTop="18dp">

                <TextView
                    android:id="@+id/tvProductoAnimacionResolucionStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_chip_borde_redondo"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_medium"
                    android:maxLines="1"
                    android:paddingStart="16dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp"
                    android:text="Producto"
                    android:textColor="@color/text_primary_pure"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/imgPapeleraResolucionStock"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="@drawable/bg_pill_error"
                    android:padding="12dp"
                    android:src="@drawable/deleteiconitem"
                    android:visibility="gone"
                    app:tint="#B42318" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvPresentacionActualResolucionStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:textColor="#667085"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTituloResolucionStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter_bold"
                android:text="Producto ya no disponible"
                android:textColor="@color/text_primary_pure"
                android:textSize="23sp" />

            <TextView
                android:id="@+id/tvMensajeResolucionStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_regular"
                android:lineSpacingExtra="2dp"
                android:text="Texto de ayuda"
                android:textColor="#344054"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSugerenciaResolucionStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_pill_green_soft"
                android:fontFamily="@font/inter_medium"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="Te sugiero: ..."
                android:textColor="#047857"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDetalleResolucionStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_regular"
                android:textColor="#667085"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResolverStockPrincipal"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/inter_bold"
                android:text="Resolver"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                app:backgroundTint="@color/text_primary_pure"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResolverStockSecundario"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter_medium"
                android:text="Revisar carrito"
                android:textAllCaps="false"
                android:textColor="#475467"
                android:textSize="14sp"
                app:strokeColor="#D0D5DD"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
