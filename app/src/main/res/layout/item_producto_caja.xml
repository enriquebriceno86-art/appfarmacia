<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="10dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="25dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/border_neutral"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Indicador lateral premium (Muestra el estado/categoria del item) -->
        <View
            android:layout_width="4dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_pill_green_soft"
            android:alpha="0.6"
            app:layout_constraintBottom_toBottomOf="@id/tvNombreProducto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvNombreProducto" />

        <!-- Nombre del producto -->
        <TextView
            android:id="@+id/tvNombreProducto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="10dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter_bold"
            android:maxLines="2"
            android:text="Panadol"
            android:textColor="@color/text_primary_pure"
            android:textSize="16sp"
            android:letterSpacing="-0.01"
            app:layout_constraintEnd_toStartOf="@id/tvSubtotal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Precio / subtotal -->
        <TextView
            android:id="@+id/tvSubtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/inter_bold"
            android:gravity="end"
            android:text="$15.98"
            android:textColor="@color/text_primary_pure"
            android:textSize="17sp"
            app:layout_constraintTop_toTopOf="@id/tvNombreProducto"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Presentacion + precio unitario -->
        <TextView
            android:id="@+id/tvDetalleCantidadPrecio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter_medium"
            android:maxLines="1"
            android:text="Tableta • $7.99 c/u"
            android:textColor="@color/text_secondary_gray"
            android:textSize="12sp"
            android:alpha="0.8"
            app:layout_constraintEnd_toStartOf="@+id/layoutControlesCantidad"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvNombreProducto" />

        <!-- Numero de lote (Chip style refinado) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#F8FAFC"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDetalleCantidadPrecio">

            <TextView
                android:id="@+id/tvLoteConsumoCaja"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:ellipsize="end"
                android:fontFamily="@font/inter_semibold"
                android:maxLines="1"
                android:text="Lote: P001"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Stepper Unificado Premium -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutControlesCantidad"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#F1F5F9"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvSubtotal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnMenos"
                    android:layout_width="42dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="Restar"
                    android:padding="11dp"
                    android:src="@drawable/baseline_remove_24"
                    app:tint="@color/text_secondary_slate" />

                <TextView
                    android:id="@+id/tvCantidad"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:text="01"
                    android:textColor="@color/text_primary_pure"
                    android:textSize="16sp" />

                <ImageButton
                    android:id="@+id/btnMas"
                    android:layout_width="52dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_boton_sumar_caja"
                    android:contentDescription="Sumar"
                    android:padding="11dp"
                    android:src="@drawable/baseline_add_24"
                    app:tint="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Vistas antiguas ocultas para no romper el adapter si las busca -->


    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
