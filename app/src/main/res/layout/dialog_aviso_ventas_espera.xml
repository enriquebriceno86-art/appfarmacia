<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="18dp">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_icon_error"
        android:foregroundGravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_info"
            app:tint="#D93025" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvTituloAvisoVentasEspera"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Atencion"
        android:textColor="@color/text_primary_pure"
        android:textSize="20sp"
        android:fontFamily="@font/inter_medium" />

    <TextView
        android:id="@+id/tvMensajeAvisoVentasEspera"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:text="Mensaje"
        android:textColor="#4B5563"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEntendidoAvisoVentasEspera"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="22dp"
        android:text="Entendido"
        android:textAllCaps="false"
        android:textColor="@color/surface_white"
        app:backgroundTint="@color/text_primary_pure"
        app:cornerRadius="16dp" />

</LinearLayout>
