<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FEF3C7"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="#F59E0B"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <!-- Fila superior: imagen + nombre/subtítulo + badge + flecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="46dp"
                android:layout_height="46dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="#F2D58A"
                app:strokeWidth="1dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProductoAlerta"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/iconpastillas" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreAlerta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_medium"
                    android:maxLines="1"
                    android:textColor="@color/text_primary_alt"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Loritox" />

                <TextView
                    android:id="@+id/tvCategoriaAlerta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#7C5300"
                    android:textSize="12sp"
                    tools:text="Antigripal · Caja 1 unidad" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvBadgeAlerta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_badge_alerta_inventario"
                android:fontFamily="@font/inter_medium"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="Por vencer"
                android:textColor="@color/state_warning"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Por vencer" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="6dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_chevron_right"
                app:tint="#92400E" />
        </LinearLayout>

        <!-- Fila de estadísticas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stock"
                    android:textColor="#7C5300"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvStockAlerta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/state_warning"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="10 uds" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vence"
                    android:textColor="#7C5300"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvVenceAlerta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/state_warning"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="04/26" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mínimo"
                    android:textColor="#7C5300"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvMinimoAlerta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/text_primary_alt"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="2 uds" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerLotesAlerta"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Ver lotes"
                android:textAllCaps="false"
                android:textColor="@color/brand_green_dark"
                android:textSize="14sp"
                app:backgroundTint="@color/surface_white"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_receipt"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="18dp"
                app:iconTint="@color/brand_green_dark"
                app:strokeColor="@color/brand_green_dark"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIngresarStockAlerta"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Ingresar stock"
                android:textAllCaps="false"
                android:textColor="@color/surface_white"
                android:textSize="14sp"
                app:backgroundTint="@color/brand_green_dark"
                app:cornerRadius="14dp"
                app:icon="@drawable/baseline_add_24"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="18dp"
                app:iconTint="@color/surface_white" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
