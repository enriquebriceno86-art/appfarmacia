<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_white"
    tools:context=".ActivityFragmentos.Fragmentos.FragmentoPrincipal">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="20dp"
            android:paddingEnd="18dp"
            android:paddingBottom="24dp">

            <!-- Cabecera: Hola + Resumen + fecha + avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSaludoPrincipal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/inter_regular"
                        android:maxLines="1"
                        android:text="Hola"
                        android:textColor="@color/brand_green_alt"
                        android:textSize="14sp"
                        tools:text="Hola, admintmp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:fontFamily="@font/inter_medium"
                        android:maxLines="1"
                        android:text="Resumen de hoy"
                        android:textColor="@color/text_primary_navy"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFechaPrincipal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:fontFamily="@font/inter_regular"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="@color/text_tertiary_alt"
                        android:textSize="12sp"
                        tools:text="Jueves, 23 de abril de 2026" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    app:cardBackgroundColor="#E6F4EC"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/iconpersona"
                        app:tint="@color/brand_green_alt" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Card Ventas totales de hoy -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#E6F4EC"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_dashboard_cart"
                        app:tint="@color/brand_green_alt" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter_regular"
                        android:text="Ventas totales de hoy"
                        android:textColor="@color/text_primary_navy"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvVentaNetaDia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter_regular"
                        android:text="Bs 0.00"
                        android:textColor="@color/brand_green_alt"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        tools:text="Bs 0.00" />

                    <!-- Comparativa vs ayer (oculta si no hay datos relevantes) -->
                    <TextView
                        android:id="@+id/tvComparativaAyer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="#16824A"
                        android:textSize="11sp"
                        android:visibility="gone" />

                    <!-- Mini KPIs en fila: Tickets, Ganancia, Efectivo, Tarjeta -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:weightSum="4">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_kpi_chip_white"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_receipt"
                                app:tint="@color/brand_green_alt" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter_regular"
                                android:text="Tickets"
                                android:textColor="@color/text_secondary_alt"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvTicketsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/inter_medium"
                                android:text="0"
                                android:textColor="@color/text_primary_navy"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="3dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_kpi_chip_white"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_dashboard_trending"
                                app:tint="@color/brand_green_alt" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter_regular"
                                android:text="Ganancia"
                                android:textColor="@color/text_secondary_alt"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvGananciaEstimada"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/inter_medium"
                                android:maxLines="1"
                                android:text="Bs 0.00"
                                android:textColor="@color/text_primary_navy"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="3dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_kpi_chip_white"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                android:src="@drawable/iconoefectivo"
                                app:tint="@color/brand_green_alt" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter_regular"
                                android:text="Efectivo"
                                android:textColor="@color/text_secondary_alt"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvEfectivoDia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/inter_medium"
                                android:maxLines="1"
                                android:text="Bs 0.00"
                                android:textColor="@color/text_primary_navy"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_kpi_chip_white"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                android:src="@drawable/iconotarjetadepago"
                                app:tint="@color/brand_green_alt" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter_regular"
                                android:text="Tarjeta"
                                android:textColor="@color/text_secondary_alt"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvTarjetaDia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/inter_medium"
                                android:maxLines="1"
                                android:text="Bs 0.00"
                                android:textColor="@color/text_primary_navy"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPrioridadDia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#FFF7E8"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#F6D89E"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="#FFE9B8"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_dashboard_bell"
                            app:tint="#9A6700" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTituloPrioridadDia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Qué revisar primero"
                            android:textColor="#7A4E00"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvResumenPrioridadDia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Todo está en orden por ahora."
                            android:textColor="#7A5D10"
                            android:textSize="13sp"
                            tools:text="Hay 2 productos por vencer que conviene revisar hoy." />

                        <TextView
                            android:id="@+id/tvAccionPrioridadDia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="4dp"
                            android:text="Ver alertas"
                            android:textColor="#9A6700"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Estado de cajas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@null"
                            android:src="@drawable/pos"
                            app:tint="@color/brand_green_alt" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/inter_medium"
                            android:text="Estado de cajas"
                            android:textColor="@color/text_primary_navy"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Chips resumen: total / abiertas / cerradas / con diferencia -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipTotalCajas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_dashboard_neutral"
                            android:fontFamily="@font/inter_medium"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="0 cajas"
                            android:textColor="@color/text_secondary_alt"
                            android:textSize="12sp"
                            tools:text="4 cajas" />

                        <TextView
                            android:id="@+id/chipCajasAbiertas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_chip_dashboard_success"
                            android:fontFamily="@font/inter_medium"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="0 abiertas"
                            android:textColor="@color/brand_green_alt"
                            android:textSize="12sp"
                            tools:text="1 abierta" />

                        <TextView
                            android:id="@+id/chipCajasCerradas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_chip_dashboard_neutral"
                            android:fontFamily="@font/inter_medium"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="0 cerradas"
                            android:textColor="@color/text_secondary_alt"
                            android:textSize="12sp"
                            tools:text="2 cerradas" />

                        <TextView
                            android:id="@+id/chipCajasDiferencia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_chip_dashboard_warning"
                            android:fontFamily="@font/inter_medium"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="0 con diferencia"
                            android:textColor="#C78100"
                            android:textSize="12sp"
                            android:visibility="gone"
                            tools:text="1 con diferencia"
                            tools:visibility="visible" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvEstadoCajas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_estado_caja_dashboard" />

                    <TextView
                        android:id="@+id/tvSinCajasDashboard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/inter_regular"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="Aún no hay cajas registradas."
                        android:textColor="@color/text_tertiary_alt"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvVerCajas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/inter_medium"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="Ver cajas  ›"
                        android:textColor="@color/brand_green_alt"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Alertas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_dashboard_bell"
                            app:tint="@color/brand_green_alt" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/inter_medium"
                            android:text="Alertas"
                            android:textColor="@color/text_primary_navy"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowAlertaBajoStock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="6dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardBackgroundColor="#FFF3D6"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/inventory_2icon"
                                app:tint="#C78100" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvAlertaBajoStock"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter_regular"
                            android:text="0 productos con bajo stock"
                            android:textColor="@color/text_primary_navy"
                            android:textSize="14sp"
                            tools:text="3 productos con bajo stock" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary_alt" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowAlertaPorVencer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="6dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardBackgroundColor="#FDE1E1"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_dashboard_calendar"
                                app:tint="#C62828" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvAlertaPorVencer"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter_regular"
                            android:text="0 productos por vencer"
                            android:textColor="@color/text_primary_navy"
                            android:textSize="14sp"
                            tools:text="5 productos por vencer" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary_alt" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowAlertaCajaDiferencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="6dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardBackgroundColor="#FDE1E1"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_dashboard_warning"
                                app:tint="#C62828" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvAlertaCajaDiferencia"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter_regular"
                            android:text="0 cajas con diferencia"
                            android:textColor="@color/text_primary_navy"
                            android:textSize="14sp"
                            tools:text="1 caja con diferencia" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary_alt" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSinAlertasDashboard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/inter_regular"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="Sin alertas por ahora."
                        android:textColor="@color/text_tertiary_alt"
                        android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Últimos cierres -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_dashboard_clock"
                            app:tint="@color/brand_green_alt" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter_medium"
                            android:text="Últimos cierres"
                            android:textColor="@color/text_primary_navy"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvVerMasCierre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/inter_medium"
                            android:padding="6dp"
                            android:text="Ver más"
                            android:textColor="@color/brand_green_alt"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvDiasCierre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:visibility="gone"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_dia_cierre_dashboard"
                        tools:visibility="visible" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvUltimosCierres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        tools:itemCount="2"
                        tools:listitem="@layout/item_ultimo_cierre_dashboard" />

                    <TextView
                        android:id="@+id/tvSinUltimosCierres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/inter_regular"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="No hay cierres en los últimos 7 días."
                        android:textColor="@color/text_tertiary_alt"
                        android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutLoadingInicialPrincipal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/surface_white"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:indeterminateTint="@color/brand_green_alt"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
