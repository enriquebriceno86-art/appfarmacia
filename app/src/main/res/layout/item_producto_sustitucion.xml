<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProductoSustitucion"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgProductoSustitucion"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/surface_subtle_blue"
            android:scaleType="centerCrop"
            android:src="@drawable/iconpastillas"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

        <TextView
            android:id="@+id/tvNombreProductoSustitucion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter_medium"
            android:maxLines="2"
            android:text="Producto"
            android:textColor="@color/text_primary_alt"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCategoriaProductoSustitucion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Categoría"
            android:textColor="@color/text_secondary_gray"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvStockProductoSustitucion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_stock_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Stock vendible"
            android:textColor="#0F766E"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvPrecioProductoSustitucion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="S/ 0.00"
            android:textColor="@color/text_primary_alt"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeleccionarProductoSustitucion"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Seleccionar"
            app:strokeColor="#BFDBFE"
            android:textColor="#2563EB" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
