<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FD"
    tools:context=".ActivityFragmentos.Fragmentos.FragmentoPerfil">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@android:color/white"
            app:contentScrim="@android:color/white"
            app:statusBarScrim="@android:color/white"
            app:collapsedTitleTextAppearance="@style/TextAppearance.Material3.TitleMedium"
            app:expandedTitleMarginBottom="12dp"
            app:expandedTitleMarginStart="20dp"
            app:expandedTitleTextAppearance="@style/TextAppearance.Material3.HeadlineLarge"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:title="Perfil"
            app:titleCollapseMode="fade">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/white"
                app:layout_collapseMode="pin" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp">

            <!-- Header Card: Info de Usuario -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="1dp"
                android:visibility="gone"
                app:strokeColor="#E0E6F3"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardBackgroundColor="#E3F2FD"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <TextView
                            android:id="@+id/tvIniciales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/inter_bold"
                            android:text="AD"
                            android:textColor="#1976D2"
                            android:textSize="24sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNombreUsuario"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="Administrador"
                            android:textColor="#1A1C1E"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvRolUsuario"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/inter_medium"
                            android:text="Gesti&#xF3;n Total"
                            android:textColor="#6C757D"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/inter_bold"
                android:text="ESTABLECIMIENTO"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="1dp"
                app:strokeColor="#E0E6F3"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="4dp">

                    <include layout="@layout/item_perfil_menu"
                        android:id="@+id/tiendaClick" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F3F9" android:layout_marginStart="72dp" />

                    <include layout="@layout/item_perfil_menu"
                        android:id="@+id/horariosClick" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F3F9" android:layout_marginStart="72dp" />

                    <include layout="@layout/item_perfil_menu"
                        android:id="@+id/tiposPagoClick" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/inter_bold"
                android:text="ADMINISTRACI&#xD3;N"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="1dp"
                app:strokeColor="#E0E6F3"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="4dp">

                    <include layout="@layout/item_perfil_menu"
                        android:id="@+id/usuariosClick" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F3F9" android:layout_marginStart="72dp" />

                    <include layout="@layout/item_perfil_menu"
                        android:id="@+id/reportesClick" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/inter_bold"
                android:text="SISTEMA Y APP"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="1dp"
                app:strokeColor="#E0E6F3"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="4dp">

                    <include layout="@layout/item_perfil_menu"
                        android:id="@+id/configuracionesClick" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F3F9" android:layout_marginStart="72dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/salirClick"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/inter_bold"
                android:text="Cerrar sesi&#xF3;n"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                app:cornerRadius="20dp"
                app:icon="@drawable/saliricon"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="24dp"
                app:iconTint="#D32F2F"
                app:rippleColor="#10D32F2F" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/inter_medium"
                android:text="Versi&#xF3;n 3.45.0 (Build 882)"
                android:textColor="#BDBDBD"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
