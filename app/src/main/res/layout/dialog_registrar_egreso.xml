<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="30dp"
    app:cardElevation="0dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="22dp">

            <!-- Título y subtítulo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="#F2FBF7"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#D8F1E4"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/iconegreso" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Registrar egreso de caja"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="20dp" />

                </LinearLayout>
            </LinearLayout>


            <TextView
                android:id="@+id/tvEfectivoDisponibleEgreso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:textColor="#2E7D32" />

            <!-- Monto -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMontoEgresoDialog"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                app:boxBackgroundColor="@android:color/white"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeColor="#DCE6DF"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:prefixTextColor="@color/text_primary_pure">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMontoEgresoDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:hint="0.00"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionNext"
                    android:textColor="@color/text_primary_pure"
                     />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Categoría de gasto (dropdown) -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:boxBackgroundColor="@android:color/white"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeColor="#E3EAF0"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="dropdown_menu">

                <AutoCompleteTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Categoría de gasto"
                    android:inputType="none"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="@color/text_primary_pure"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Motivo / descripción -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMotivoEgresoDialog"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:boxBackgroundColor="@android:color/white"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeColor="#E3EAF0"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMotivoEgresoDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Motivo / descripción *"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minLines="2"
                    android:imeOptions="actionNext"
                    android:textColor="@color/text_primary_pure"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Beneficiario (opcional) y tipo de comprobante en una fila -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:boxBackgroundColor="@android:color/white"
                    app:boxCornerRadiusBottomEnd="20dp"
                    app:boxCornerRadiusBottomStart="20dp"
                    app:boxCornerRadiusTopEnd="20dp"
                    app:boxCornerRadiusTopStart="20dp"
                    app:boxStrokeColor="#E3EAF0"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Beneficiario (opcional)"
                        android:inputType="textCapSentences"
                        android:imeOptions="actionNext"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:boxBackgroundColor="@android:color/white"
                    app:boxCornerRadiusBottomEnd="20dp"
                    app:boxCornerRadiusBottomStart="20dp"
                    app:boxCornerRadiusTopEnd="20dp"
                    app:boxCornerRadiusTopStart="20dp"
                    app:boxStrokeColor="#E3EAF0"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="dropdown_menu">

                    <AutoCompleteTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tipo comprobante"
                        android:inputType="none"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Sección de adjuntar comprobante (foto) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Comprobante visual"
                android:textColor="#516072"
                android:textSize="13sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAdjuntarComprobanteEgreso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#F8F9FF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:rippleColor="#14000000"
                app:strokeColor="#D9D9D9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minHeight="168dp"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:id="@+id/imgPreviewComprobanteEgresoDialog"
                        android:layout_width="match_parent"
                        android:layout_height="170dp"
                        android:background="@color/divider_alt"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layoutHintComprobanteEgresoDialog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            app:cardBackgroundColor="#EAEFF7"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="14dp"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="#000000" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvHintComprobanteEgresoDialog"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center"
                            android:text="Adjuntar foto (factura, boleta o nota)"
                            android:textColor="@color/text_secondary_indigo"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/btnQuitarComprobanteEgresoDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_medium"
                android:text="Quitar comprobante"
                android:textColor="#C94747"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Botones -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarEgresoDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Guardar egreso"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="#000000"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelarEgresoDialog"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_regular"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="@color/text_primary_pure"
                android:textSize="14sp"
                app:cornerRadius="28dp"
                app:strokeColor="@color/black"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</com.google.android.material.card.MaterialCardView>
