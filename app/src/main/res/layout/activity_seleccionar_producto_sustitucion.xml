<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8FF"
    tools:context=".ActivitysCaja.ActivitySeleccionarProductoSustitucion">

    <LinearLayout
        android:id="@+id/headerSustitucion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutBusquedaSustitucion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundColor="#F1F5F9"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:endIconDrawable="@drawable/searchicon"
            app:endIconMode="custom"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/baseline_arrow_back_24"
            app:startIconTint="@color/black">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBuscarSustitucion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar producto para cambio"
                android:imeOptions="actionDone"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:padding="24dp"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutCategoriasSustitucion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:tabIndicatorColor="#2563EB"
            app:tabIndicatorFullWidth="false"
            app:tabMode="scrollable"
            app:tabRippleColor="@null"
            android:background="@color/white"
            app:tabSelectedTextColor="@color/text_primary_alt"
            app:tabTextColor="@color/text_secondary_gray" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerProductosSustitucion"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerSustitucion" />

    <ProgressBar
        android:id="@+id/progressSustitucion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/recyclerProductosSustitucion"
        app:layout_constraintEnd_toEndOf="@id/recyclerProductosSustitucion"
        app:layout_constraintStart_toStartOf="@id/recyclerProductosSustitucion"
        app:layout_constraintTop_toTopOf="@id/recyclerProductosSustitucion" />

    <LinearLayout
        android:id="@+id/layoutSinProductosSustitucion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/recyclerProductosSustitucion"
        app:layout_constraintEnd_toEndOf="@id/recyclerProductosSustitucion"
        app:layout_constraintStart_toStartOf="@id/recyclerProductosSustitucion"
        app:layout_constraintTop_toTopOf="@id/recyclerProductosSustitucion">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_medium"
            android:text="Sin productos disponibles"
            android:textColor="@color/text_secondary_strong"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvMensajeVacioSustitucion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Prueba con otra búsqueda o categoría."
            android:textColor="@color/text_secondary_gray"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
