<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tipos_pago_screen"
    tools:context=".ActivitysPerfilItem.TiposPagoActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarTiposPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:minHeight="?attr/actionBarSize"
            android:paddingHorizontal="14dp"
            app:navigationIcon="@drawable/baseline_arrow_back_24"
            app:navigationIconTint="#102A43"
            app:title=""
            tools:title="" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:orientation="horizontal"
        android:paddingStart="28dp"
        android:paddingTop="22dp"
        android:paddingEnd="28dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="22dp"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tipos_pago_hero"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipos de pago"
                        android:textColor="@android:color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Organiza los cobros de tu farmacia y crea nuevos metodos desde un solo lugar."
                        android:textColor="#E8FFF7"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/textResumenHero"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="2 activos, 0 con QR y 2 disponibles para cobro mixto."
                        android:textColor="#EAFBF4"
                        android:textSize="15sp"
                        tools:text="4 activos, 2 con QR y 3 disponibles para cobro mixto." />

                    <TextView
                        android:id="@+id/textCantidadTipos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="0"
                        android:textColor="@android:color/white"
                        android:textSize="38sp"
                        android:textStyle="bold"
                        tools:text="6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Metodos configurados"
                        android:textColor="#D7F6EA"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAgregarTipoPagoHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:minHeight="56dp"
                        android:text="Agregar metodo de pago"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        app:backgroundTint="@android:color/white"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/baseline_add_24"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="#0A8F5A" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E4ECF5"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Activos"
                            android:textColor="#5C6B82"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/textActivosCantidad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="0"
                            android:textColor="#102A43"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="4" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E4ECF5"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Con QR"
                            android:textColor="#5C6B82"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/textQrCantidad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="0"
                            android:textColor="#102A43"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="2" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E4ECF5"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cobro mixto"
                            android:textColor="#5C6B82"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/textMixtoCantidad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="0"
                            android:textColor="#102A43"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="3" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textSinTiposPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_dashboard_panel"
                android:gravity="center"
                android:padding="32dp"
                android:text="Todavia no hay metodos de pago configurados."
                android:textColor="#5C6B82"
                android:textSize="16sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTiposPago"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="12dp"
                tools:itemCount="4"
                tools:listitem="@layout/item_tipo_pago" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
