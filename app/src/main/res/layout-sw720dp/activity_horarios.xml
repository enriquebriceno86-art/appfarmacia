<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_subtle"
    tools:context=".ActivitysPerfilItem.HorariosActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_subtle"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:navigationIcon="@drawable/baseline_arrow_back_24"
            app:title="Horarios de Atención"
            app:titleCentered="false"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="@color/text_primary_pure" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="64dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guidelineStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.15" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guidelineEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.85" />

            <!-- 🔴 ESTADO VACÍO -->
            <LinearLayout
                android:id="@+id/layoutSinHorarios"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="64dp"
                android:layout_marginTop="64dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_subtle"
                    app:strokeWidth="1dp">
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:src="@drawable/horariostiendaicon"
                        app:tint="@color/text_secondary_blue" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Sin horarios configurados"
                    android:textColor="@color/text_primary_pure"
                    android:textSize="28sp"
                    android:fontFamily="@font/inter_medium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCrearHorario"
                    android:layout_width="wrap_content"
                    android:layout_height="72dp"
                    android:layout_marginTop="48dp"
                    android:paddingHorizontal="48dp"
                    android:text="Configurar ahora"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/text_primary_pure"
                    app:cornerRadius="36dp" />

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:chipSpacingHorizontal="16dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEmptyTemplateLaborales"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lunes a Viernes" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEmptyTemplate24h"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atención 24 horas" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- 🟢 1. RESUMEN SEMANAL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResumenSemanal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Resumen de Operación"
                            android:textColor="@color/text_primary_pure"
                            android:textSize="20sp"
                            android:fontFamily="@font/inter_bold" />
                        <TextView
                            android:id="@+id/txtDiasConfigurados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/7 días"
                            android:textColor="@color/text_secondary_blue"
                            android:textSize="18sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/txtCerrados24h"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 cerrados · 0 24h"
                                android:textColor="@color/text_primary_pure"
                                android:textSize="18sp"
                                android:fontFamily="@font/inter_medium" />
                            <TextView
                                android:id="@+id/txtRangoHoras"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="--:-- a --:--"
                                android:textColor="@color/text_secondary_gray"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⚡ 2. PLANTILLAS RÁPIDAS -->
            <LinearLayout
                android:id="@+id/layoutPlantillasContenedor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/cardResumenSemanal"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configuraciones Sugeridas"
                    android:textColor="@color/text_secondary_gray"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupTemplates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:chipSpacingHorizontal="16dp">
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTemplateLaborales"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lunes a Viernes" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTemplateFull"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Todos los días" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTemplate24h"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Atención 24 horas" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTemplateCerrarDomingo"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Domingos Cerrado" />
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 🟢 3. LISTA DE HORARIOS -->
            <LinearLayout
                android:id="@+id/layoutRecyclerHorariosContenedor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/layoutPlantillasContenedor"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Horarios de Atención"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="20sp"
                        android:fontFamily="@font/inter_bold" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAgregarHorarioInline"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agregar"
                        android:textSize="16sp"
                        app:icon="@drawable/baseline_add_24" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerHorarios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingTop="8dp" />
            </LinearLayout>

            <!-- 🟠 4. SECCIÓN EXCEPCIONES -->
            <LinearLayout
                android:id="@+id/layoutExcepciones"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/layoutRecyclerHorariosContenedor"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Excepciones y Feriados Próximos"
                        android:textColor="@color/text_primary_pure"
                        android:textSize="20sp"
                        android:fontFamily="@font/inter_bold" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAgregarExcepcion"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agregar Excepción"
                        android:textSize="16sp"
                        app:icon="@drawable/baseline_add_24" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerExcepciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <!-- 🤖 5. SECCIÓN IA -->
            <LinearLayout
                android:id="@+id/layoutAiContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="48dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/layoutExcepciones"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
