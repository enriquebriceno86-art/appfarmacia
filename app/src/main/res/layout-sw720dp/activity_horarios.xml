<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_subtle"
    tools:context=".ActivitysPerfilItem.HorariosActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_subtle"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:navigationIcon="@drawable/baseline_arrow_back_24"
            app:title="Horarios de Atención"
            app:titleCentered="false"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="@color/text_primary_pure" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.15" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.85" />

        <!-- 🔴 ESTADO VACÍO -->
        <LinearLayout
            android:id="@+id/layoutSinHorarios"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp"
            android:layout_marginTop="100dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="60dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@drawable/horariostiendaicon"
                    app:tint="@color/text_secondary_blue" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Sin horarios configurados"
                android:textColor="@color/text_primary_pure"
                android:textSize="28sp"
                android:fontFamily="@font/inter_medium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Define los días y horas en los que tu tienda estará abierta al público para que tus clientes puedan planificar sus compras."
                android:textColor="@color/text_secondary_blue"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCrearHorario"
                android:layout_width="wrap_content"
                android:layout_height="64dp"
                android:layout_marginTop="40dp"
                android:paddingHorizontal="48dp"
                android:text="Configurar ahora"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:fontFamily="@font/inter_medium"
                android:textSize="18sp"
                app:backgroundTint="@color/text_primary_pure"
                app:cornerRadius="32dp" />
        </LinearLayout>

        <!-- 🟢 LISTA DE HORARIOS -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerHorarios"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clipToPadding="false"
            android:paddingTop="24dp"
            android:paddingBottom="120dp"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BOTÓN FLOTANTE -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAgregarHorario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="40dp"
        android:text="Agregar Horario"
        android:textColor="@color/white"
        android:fontFamily="@font/inter_medium"
        android:textSize="16sp"
        app:icon="@drawable/baseline_add_24"
        app:iconSize="24dp"
        app:iconTint="@color/white"
        android:visibility="gone"
        app:backgroundTint="@color/text_primary_pure" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>