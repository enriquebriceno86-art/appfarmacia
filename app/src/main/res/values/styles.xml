<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearanceOverlay.App.CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="NavRailActiveIndicator" parent="">
        <item name="android:width">64dp</item>
        <item name="android:height">52dp</item>
        <item name="shapeAppearance">@style/NavRailActiveIndicatorShape</item>
    </style>

    <style name="NavRailActiveIndicatorShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="NavRailTextActive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
    </style>

    <style name="NavRailTextInactive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
    </style>


    <style name="PopupGrisRedondeado" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_gris</item>
    </style>

</resources>
